diff --git a/ledger/bank.py b/ledger/bank.py
index 91989bc..69c801c 100644
--- a/ledger/bank.py
+++ b/ledger/bank.py
@@ -20,35 +20,64 @@ class Bank:
         self._log = []
         self._balances = {}
 
+    def _emit(self, event):
+        self._log.append(event)
+        self._balances = apply_event(self._balances, event)
+
+    def _require(self, account_id):
+        if account_id not in self._balances:
+            raise ValueError(f"unknown account: {account_id}")
+
     def open_account(self, account_id):
         """Open a new account at zero balance. ValueError if it already exists."""
-        raise NotImplementedError
+        if account_id in self._balances:
+            raise ValueError(f"account already exists: {account_id}")
+        self._emit(AccountOpened(account_id))
 
     def deposit(self, account_id, amount):
         """Add ``amount`` (> 0) to an existing account."""
-        raise NotImplementedError
+        self._require(account_id)
+        if amount <= 0:
+            raise ValueError("amount must be positive")
+        self._emit(Deposited(account_id, amount))
 
     def withdraw(self, account_id, amount):
         """Remove ``amount`` (> 0); InsufficientFunds if the balance is too low."""
-        raise NotImplementedError
+        self._require(account_id)
+        if amount <= 0:
+            raise ValueError("amount must be positive")
+        if self._balances[account_id] < amount:
+            raise InsufficientFunds(account_id)
+        self._emit(Withdrawn(account_id, amount))
 
     def transfer(self, src, dst, amount):
         """Move ``amount`` from ``src`` to ``dst`` atomically."""
-        raise NotImplementedError
+        self._require(src)
+        self._require(dst)
+        if amount <= 0:
+            raise ValueError("amount must be positive")
+        if self._balances[src] < amount:
+            raise InsufficientFunds(src)
+        self._emit(Withdrawn(src, amount))
+        self._emit(Deposited(dst, amount))
 
     def balance(self, account_id):
         """Return the current balance of an existing account."""
-        raise NotImplementedError
+        self._require(account_id)
+        return self._balances[account_id]
 
     def snapshot(self):
         """Return a copy of the current balances (account id -> balance)."""
-        raise NotImplementedError
+        return dict(self._balances)
 
     def history(self):
         """Return the ordered event log."""
-        raise NotImplementedError
+        return list(self._log)
 
     @classmethod
     def from_history(cls, events):
         """Rebuild a bank by replaying ``events``."""
-        raise NotImplementedError
+        bank = cls()
+        bank._log = list(events)
+        bank._balances = replay(bank._log)
+        return bank
diff --git a/ledger/events.py b/ledger/events.py
index 2e8216b..cd5ef4a 100644
--- a/ledger/events.py
+++ b/ledger/events.py
@@ -30,9 +30,21 @@ def apply_event(state, event):
 
     ``state`` maps account id -> balance and must not be mutated.
     """
-    raise NotImplementedError
+    new = dict(state)
+    if isinstance(event, AccountOpened):
+        new.setdefault(event.account_id, 0)
+    elif isinstance(event, Deposited):
+        new[event.account_id] = new[event.account_id] + event.amount
+    elif isinstance(event, Withdrawn):
+        new[event.account_id] = new[event.account_id] - event.amount
+    else:
+        raise TypeError(f"unknown event: {event!r}")
+    return new
 
 
 def replay(events):
     """Fold a sequence of events from an empty ledger into a balances dict."""
-    raise NotImplementedError
+    state = {}
+    for event in events:
+        state = apply_event(state, event)
+    return state
