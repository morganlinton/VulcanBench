-        # (2 ** 3) ** 2.
-        node = self.atom()
-        while self.cur.kind in _BINOP:
-            op = _BINOP[self.advance().kind]
-            node = BinOp(op, node, self.atom())
+        node = self.term()
+        while self.cur.kind in _SUM_OPS:
+            op = _SUM_OPS[self.advance().kind]
+            node = BinOp(op, node, self.term())
