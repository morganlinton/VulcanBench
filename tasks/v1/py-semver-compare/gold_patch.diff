+import re
+
+_VERSION = re.compile(
+    r"^(0|[1-9]\d*)\.(0|[1-9]\d*)\.(0|[1-9]\d*)"
+    r"(?:-((?:0|[1-9]\d*|\d*[A-Za-z-][0-9A-Za-z-]*)"
+    r"(?:\.(?:0|[1-9]\d*|\d*[A-Za-z-][0-9A-Za-z-]*))*))?"
+    r"(?:\+[0-9A-Za-z-]+(?:\.[0-9A-Za-z-]+)*)?$"
+)
+
+
+def _parse(v):
+    m = _VERSION.match(v)
+    if not m:
+        raise ValueError(f"invalid semver: {v!r}")
+    major, minor, patch, pre = m.groups()
+    return int(major), int(minor), int(patch), pre
+
+
+def _sign(x):
+    return (x > 0) - (x < 0)
+
+
+def _cmp_identifier(a, b):
+    a_num, b_num = a.isdigit(), b.isdigit()
+    if a_num and b_num:
+        return _sign(int(a) - int(b))
+    if a_num:
+        return -1  # numeric identifiers are lower precedence than alphanumeric
+    if b_num:
+        return 1
+    return _sign((a > b) - (a < b))
+
+
+def _cmp_prerelease(a_pre, b_pre):
+    if a_pre is None and b_pre is None:
+        return 0
+    if a_pre is None:
+        return 1  # a release outranks a prerelease
+    if b_pre is None:
+        return -1
+    a_ids, b_ids = a_pre.split("."), b_pre.split(".")
+    for ai, bi in zip(a_ids, b_ids):
+        c = _cmp_identifier(ai, bi)
+        if c != 0:
+            return c
+    return _sign(len(a_ids) - len(b_ids))  # more fields wins when all else equal
+
+
 def compare(a, b):
-    """Compare two semantic versions, returning -1, 0, or 1 (see issue.md)."""
-    raise NotImplementedError
+    """Return -1, 0, or 1 comparing semver a vs b. Build metadata is ignored."""
+    ca = _parse(a)
+    cb = _parse(b)
+    if ca[:3] != cb[:3]:
+        return _sign((ca[:3] > cb[:3]) - (ca[:3] < cb[:3]))
+    return _cmp_prerelease(ca[3], cb[3])
