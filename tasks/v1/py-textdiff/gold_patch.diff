 """Compute a line-level diff between two sequences of lines.
 
-NOTE: diff is not implemented — see issue.md. It must produce a minimal edit
-script (longest common subsequence of kept lines) made of ("keep"|"del"|"ins",
-line) operations, consumed by ``textdiff/patch.py``.
+``diff`` produces a minimal edit script whose kept lines form a longest common
+subsequence of the two inputs. The script is consumed by ``textdiff/patch.py``.
 """
 
 
@@ -11,6 +10,35 @@ def diff(a, b):
 
     Each op is a tuple: ("keep", line) for a line common to both, ("del", line)
     for a line only in ``a``, ("ins", line) for a line only in ``b``. The kept
-    lines must form a longest common subsequence of ``a`` and ``b``.
+    lines form a longest common subsequence of ``a`` and ``b``.
     """
-    raise NotImplementedError
+    n, m = len(a), len(b)
+    # dp[i][j] = LCS length of a[i:] and b[j:]
+    dp = [[0] * (m + 1) for _ in range(n + 1)]
+    for i in range(n - 1, -1, -1):
+        for j in range(m - 1, -1, -1):
+            if a[i] == b[j]:
+                dp[i][j] = dp[i + 1][j + 1] + 1
+            else:
+                dp[i][j] = max(dp[i + 1][j], dp[i][j + 1])
+
+    ops = []
+    i = j = 0
+    while i < n and j < m:
+        if a[i] == b[j]:
+            ops.append(("keep", a[i]))
+            i += 1
+            j += 1
+        elif dp[i + 1][j] >= dp[i][j + 1]:
+            ops.append(("del", a[i]))
+            i += 1
+        else:
+            ops.append(("ins", b[j]))
+            j += 1
+    while i < n:
+        ops.append(("del", a[i]))
+        i += 1
+    while j < m:
+        ops.append(("ins", b[j]))
+        j += 1
+    return ops
