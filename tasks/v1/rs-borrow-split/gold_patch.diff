     pub fn get_mut(&mut self, index: usize) -> Option<&mut T> {
         self.data.get_mut(index)
     }
+
+    /// Returns two non-overlapping mutable references to elements at `i` and `j`.
+    ///
+    /// Panics if `i == j` (cannot have two mutable refs to the same slot).
+    /// Returns `None` if either index is out of bounds.
+    pub fn get_two_mut(&mut self, i: usize, j: usize) -> Option<(&mut T, &mut T)> {
+        assert!(i != j, "cannot get two mutable refs to the same index");
+        if i >= self.data.len() || j >= self.data.len() {
+            return None;
+        }
+        let (lo, hi) = if i < j { (i, j) } else { (j, i) };
+        let (left, right) = self.data.split_at_mut(hi);
+        let a = &mut left[lo];
+        let b = &mut right[0];
+        if i < j {
+            Some((a, b))
+        } else {
+            Some((b, a))
+        }
+    }
 }
 
