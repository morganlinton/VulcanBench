+        assert domain.of_type(domain.conjugate(a))
+        assert domain.conjugate(a) == a
+
+        if domain.is_Field:
+            b = domain(-5)
+            assert domain.of_type(domain.conjugate(a / b))
+            assert domain.conjugate(a / b) == domain(a / b)
+
